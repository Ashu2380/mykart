# Production Environment Variables for Frontend
# Copy this file to .env and fill in your values

# Server URL - Point to your Render backend
VITE_SERVER_URL=https://your-backend-app.onrender.com

# Frontend URL - Point to your Vercel frontend
VITE_FRONTEND_URL=https://your-frontend.vercel.app

# Razorpay Key ID
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# Firebase API Key
VITE_FIREBASE_APIKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API Key
VITE_GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx